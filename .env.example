# Copy this file to .env.local and fill in your values
# Never commit .env.local to source control

# ── Business Central API ──────────────────────────────────────────────────────
# Full base URL to your BC environment API
# Format: https://api.businesscentral.dynamics.com/v2.0/{tenantId}/{environmentName}
VITE_BC_BASE_URL=https://api.businesscentral.dynamics.com/v2.0/your-tenant-id/sandbox

# ── Azure AD App Registration ─────────────────────────────────────────────────
# Found in Azure Portal → Azure AD → App registrations → your app → Overview
VITE_CLIENT_ID=your-application-client-id
VITE_TENANT_ID=your-directory-tenant-id

# BC OAuth scope (do not change unless using on-premises)
VITE_BC_SCOPE=https://api.businesscentral.dynamics.com/.default

# ── Postman / server-side testing only ───────────────────────────────────────
# Client secret is ONLY for server-side or Postman (client_credentials flow).
# NEVER use VITE_ prefix for secrets — that would expose them in the browser bundle.
# Store in a separate .env.server.local file for any Node.js proxy you add later.
#
# CLIENT_SECRET=your-client-secret-here
#
# Token endpoint for client_credentials (Postman):
#   POST https://login.microsoftonline.com/{VITE_TENANT_ID}/oauth2/v2.0/token
#   grant_type=client_credentials
#   client_id={VITE_CLIENT_ID}
#   client_secret={CLIENT_SECRET}
#   scope=https://api.businesscentral.dynamics.com/.default
