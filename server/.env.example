# Copy this file to server/.env and fill in real values
# server/.env is git-ignored — never commit real secrets

# Azure AD App Registration (service app / client credentials)
CLIENT_ID=your-service-app-client-id
CLIENT_SECRET=your-client-secret-value
TENANT_ID=your-azure-ad-tenant-id

# BC environment name (sandbox or production)
BC_ENVIRONMENT=sandbox

# Proxy port (optional, default 3001)
PORT=3001
